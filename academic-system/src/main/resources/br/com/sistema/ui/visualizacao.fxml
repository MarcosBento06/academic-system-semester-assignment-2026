<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sistema.ui.controller.VisualizacaoController"
      spacing="16" VBox.vgrow="ALWAYS">

    <Label styleClass="section-title" text="Turmas e Avaliações"/>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <VBox spacing="6" minWidth="210" maxWidth="240">
            <Label styleClass="form-label" text="Turmas"/>
            <ListView fx:id="listTurmas" VBox.vgrow="ALWAYS"
                      onMouseClicked="#handleTurmaSelecionada"/>
            <Button styleClass="btn-secondary" text="Atualizar"
                    onAction="#handleAtualizar" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label fx:id="lblTurmaSelecionada" styleClass="form-label" text=""/>
            <TextArea fx:id="txtAvaliacoes"
                      styleClass="report-area"
                      editable="false"
                      wrapText="true"
                      VBox.vgrow="ALWAYS"/>
        </VBox>

    </HBox>
</VBox>
