<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sistema.ui.controller.TurmaFormController"
      spacing="0">

    <Label styleClass="section-title" text="Cadastrar Turma"/>

    <VBox styleClass="card" maxWidth="480" spacing="16">

        <VBox spacing="6">
            <Label styleClass="form-label" text="Código da Turma"/>
            <TextField fx:id="txtCodigo" styleClass="form-field"
                       promptText="Ex.: CC001"/>
        </VBox>

        <VBox spacing="6">
            <Label styleClass="form-label" text="Disciplina"/>
            <TextField fx:id="txtDisciplina" styleClass="form-field"
                       promptText="Ex.: Orientação a Objetos"/>
        </VBox>

        <Label fx:id="lblMensagem" styleClass="msg-success" text="" wrapText="true"/>

        <HBox spacing="12">
            <Button styleClass="btn-primary" text="Cadastrar"
                    onAction="#handleCadastrar" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-secondary" text="Limpar"
                    onAction="#handleLimpar"/>
        </HBox>

    </VBox>
</VBox>
