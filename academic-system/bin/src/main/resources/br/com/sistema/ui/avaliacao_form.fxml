<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.sistema.ui.controller.AvaliacaoFormController"
      spacing="0">

    <Label styleClass="section-title" text="Registrar Avaliação"/>

    <VBox styleClass="card" maxWidth="480" spacing="16">

        <VBox spacing="6">
            <Label styleClass="form-label" text="Turma"/>
            <ComboBox fx:id="cbTurma" styleClass="form-combo"
                      promptText="Selecione uma turma" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6">
            <Label styleClass="form-label" text="Tipo de Avaliação"/>
            <ComboBox fx:id="cbTipo" styleClass="form-combo"
                      promptText="Selecione o tipo" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6">
            <Label styleClass="form-label" text="Título"/>
            <TextField fx:id="txtTitulo" styleClass="form-field"
                       promptText="Ex.: Prova 1"/>
        </VBox>

        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Valor (0 a 10)"/>
                <TextField fx:id="txtValor" styleClass="form-field" promptText="Ex.: 10.0"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label styleClass="form-label" text="Peso (0.0 a 1.0)"/>
                <TextField fx:id="txtPeso" styleClass="form-field" promptText="Ex.: 0.4"/>
            </VBox>
        </HBox>

        <Label fx:id="lblMensagem" styleClass="msg-success" text="" wrapText="true"/>

        <HBox spacing="12">
            <Button styleClass="btn-primary" text="Registrar"
                    onAction="#handleRegistrar" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-secondary" text="Limpar"
                    onAction="#handleLimpar"/>
        </HBox>

    </VBox>
</VBox>
